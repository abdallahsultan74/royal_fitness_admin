# Supabase (required for production panel)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional fallback login used when no staff session exists (e.g. serverless first load).
# Must be a real Supabase Auth user whose public.profiles.role is admin or coach.
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=

# Set true only for local UI demo without Supabase login (data may still need RLS).
VITE_LOCAL_AUTH=false

# Legacy Firebase keys (unused if panel uses Supabase only)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
